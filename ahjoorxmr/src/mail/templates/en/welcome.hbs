<!DOCTYPE html>
<html>
<head>
<style>
  body { font-family: Arial, sans-serif; background: #f4f4f4; margin: 0; padding: 0; }
  .container { max-width: 600px; margin: 40px auto; background: #fff; border-radius: 8px; padding: 32px; }
  .btn { display: inline-block; padding: 12px 24px; background: #4f46e5; color: #fff; text-decoration: none; border-radius: 6px; }
  .footer { margin-top: 32px; font-size: 12px; color: #888; }
</style>
</head>
<body>
  <div class="container">
    <h1>Welcome to Ahjoorxmr, {{userName}}!</h1>
    <p>Your account has been created with <strong>{{email}}</strong>.</p>
    <p>Please activate your account:</p>
    <a class="btn" href="{{activationLink}}">Activate Account</a>
    <div class="footer">If you did not create this account, please ignore this email.</div>
  </div>
</body>
</html>
