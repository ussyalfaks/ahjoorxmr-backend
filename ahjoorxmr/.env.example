# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=ahjoorxmr
DB_LOGGING=false

# Test Database Configuration
DB_TEST_HOST=localhost
DB_TEST_PORT=5432
DB_TEST_USERNAME=postgres
DB_TEST_PASSWORD=postgres
DB_TEST_NAME=ahjoorxmr_test

# Database Connection Pool Configuration
DB_POOL_MAX=20                    # Maximum number of connections in the pool
DB_POOL_MIN=2                     # Minimum number of connections maintained
DB_IDLE_TIMEOUT=30000             # Time (ms) a connection can be idle before closing
DB_CONNECTION_TIMEOUT=2000        # Time (ms) to wait for connection before timeout
DB_SSL=false                      # Enable SSL for database connections (true for production)
DB_CACHE_ENABLED=false            # Enable TypeORM query caching with Redis

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# Application Configuration
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Mail Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM="Ahjoorxmr <noreply@ahjoorxmr.com>"
MAIL_LOCALE=en

# JWT Configuration
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_PRIVATE_KEY=your_private_key_here
JWT_REFRESH_SECRET=your_refresh_secret_here

# Stellar Configuration
STELLAR_NETWORK=testnet
STELLAR_ISSUER_ACCOUNT=your_issuer_account_here
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_CIRCUIT_BREAKER_THRESHOLD=5
STELLAR_CIRCUIT_BREAKER_TIMEOUT=60
STELLAR_ALERT_WEBHOOK_URL=

# Stellar Balance Monitor Configuration
BALANCE_CHECK_INTERVAL_MS=900000                    # 15 minutes (check interval for balance monitoring)
STELLAR_MIN_BALANCE_ALERT_XLM=5                     # Minimum balance threshold (in XLM) before alerting

# ── Issue #XXX: Dynamic Fee Estimation & Budget Caps ───────────────────────────
STELLAR_MAX_FEE_STROOPS=500000                      # Maximum allowed fee per transaction (stroops; 500000 = 0.05 XLM)
STELLAR_FEE_BUFFER_PERCENT=20                       # Percentage buffer added to simulated fee (default 20%)
STELLAR_DAILY_FEE_ALERT_XLM=10                      # Daily fee spend threshold (XLM); triggers webhook alert when exceeded

# Queue Configuration
REDIS_HOST_BULLMQ=localhost
REDIS_PORT_BULLMQ=6379

# Rate Limiting Configuration
THROTTLE_TTL=60000                # Default rate limit window in milliseconds (60s)
THROTTLE_LIMIT=100                # Default max requests per window for anonymous users
THROTTLE_LIMIT_AUTHENTICATED=200  # Max requests per window for authenticated users
THROTTLE_TTL_AUTHENTICATED=60000  # Rate limit window for authenticated users

# Authentication Rate Limiting (specific endpoints)
AUTH_LOGIN_LIMIT=5                # Max login attempts per 15 minutes
AUTH_LOGIN_TTL=900000             # Login rate limit window (15 minutes)
AUTH_REGISTER_LIMIT=10            # Max registration attempts per hour
AUTH_REGISTER_TTL=3600000         # Registration rate limit window (1 hour)
AUTH_CHALLENGE_LIMIT=20           # Max challenge requests per 5 minutes
AUTH_CHALLENGE_TTL=300000         # Challenge rate limit window (5 minutes)
AUTH_VERIFY_LIMIT=20              # Max verify attempts per 5 minutes
AUTH_VERIFY_TTL=300000            # Verify rate limit window (5 minutes)

# Group Invite Expiry Configuration
# Cron expression for the scheduled job to prune expired group invites
# Default: 0 0 2 * * * (every day at 2:00 AM UTC)
# Examples:
#   - Every hour: 0 0 * * * *
#   - Every 6 hours: 0 0 */6 * * *
#   - Every day at midnight: 0 0 0 * * *
GROUP_INVITE_EXPIRY_CRON=

# Firebase Configuration for Push Notifications (FCM)
# Get these from your Firebase project settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# The private key should include literal newlines (use quotes in .env) or escaped \n characters
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqh...\n-----END PRIVATE KEY-----\n"

# Trusted IP Configuration (for bypassing rate limits)
# Comma-separated list of trusted IP addresses
TRUSTED_IPS=127.0.0.1,::1
# Comma-separated list of IP ranges (format: start-end)
TRUSTED_IP_RANGES=10.0.0.1-10.0.0.255,172.16.0.1-172.16.255.255
# Example: TRUSTED_IPS=192.168.1.100,192.168.1.101
# Example: TRUSTED_IP_RANGES=192.168.1.1-192.168.1.255

VERIFY_CONTRIBUTIONS=true

# Stale Group Detection Configuration
MAX_STALE_GROUP_DAYS=7            # Number of days before an ACTIVE group is flagged as stale

# Group Invite Expiry Configuration
# Cron expression for the scheduled job to prune expired group invites
# Default: 0 0 2 * * * (every day at 2:00 AM UTC)
# Examples:
#   - Every hour: 0 0 * * * *
#   - Every 6 hours: 0 0 */6 * * *
#   - Every day at midnight: 0 0 0 * * *
GROUP_INVITE_EXPIRY_CRON=

# Round Auto-Advance Configuration
ROUND_GRACE_PERIOD_HOURS=0        # Grace period (hours) after round deadline before auto-advancing

# Mediation Distributed Locking
MEDIATION_LOCK_TTL_MS=30000       # TTL (ms) for the Redis distributed lock on group mediation jobs (default: 30000)

# OpenTelemetry Configuration
OTEL_EXPORTER_OTLP_ENDPOINT=      # OTLP endpoint for trace export (e.g., http://localhost:4318/v1/traces)
OTEL_SERVICE_NAME=ahjoorxmr-backend

# Logging Configuration
LOG_LEVEL=info                    # Log level: error, warn, info, debug, verbose

# PII Protection
PII_HMAC_SECRET=change-me-to-a-strong-random-secret  # HMAC key for audit log PII hashing (GDPR Art. 32)

# Audit Log Export
AUDIT_EXPORT_PII_ALLOWED=false    # Set to true to allow PII in audit exports (requires ?includePii=true)

# API Versioning Deprecation
V1_SUNSET_DATE=2026-12-31T00:00:00Z  # ISO-8601 date after which v1 routes return 410 Gone

# GDPR Data Export
GDPR_EXPORT_S3_BUCKET=your-gdpr-export-bucket
GDPR_EXPORT_EXPIRY_HOURS=24

# Database Query Performance Monitoring
DB_SLOW_QUERY_THRESHOLD_MS=500    # Threshold (ms) for logging slow queries (default: 500)
DB_QUERY_TIMEOUT_MS=5000          # Query timeout in milliseconds (default: 5000)

# Request Timeout and Slow Request Logging
REQUEST_TIMEOUT_MS=10000          # Request timeout in milliseconds (default: 10000)
SLOW_REQUEST_THRESHOLD_MS=2000    # Threshold (ms) for logging slow requests (default: 2000)

# Feature Flags
FEATURE_FLAGS=                    # JSON object of feature flags (overrides Redis for emergency kill-switches)
# Example: {"websocket_notifications":{"enabled":false,"strategy":"disabled"}}

# Metrics Configuration
METRICS_API_KEY=change-me-to-a-strong-random-secret  # API key for accessing /metrics endpoint

# ── Issue #234: Multi-Currency Asset Support ──────────────────────────────────
# Comma-separated list of allowed Stellar asset codes (default: XLM,USDC)
ALLOWED_ASSET_CODES=XLM,USDC

# ── Issue #224: Refresh Token Absolute Expiry ─────────────────────────────────
# Absolute session lifetime in days (default: 30). Sessions cannot be refreshed beyond this.
REFRESH_TOKEN_ABSOLUTE_EXPIRY_DAYS=30

# ── Issue #232: GDPR Data Export ──────────────────────────────────────────────
# Signed URL TTL in hours for data export downloads (default: 48)
DATA_EXPORT_LINK_TTL=48

# ── Issue #223: KYC File Upload ───────────────────────────────────────────────
# Maximum KYC file size in MB (default: 10)
KYC_MAX_FILE_SIZE_MB=10
# ClamAV host for virus scanning (leave empty to skip scanning with a warning)
CLAMAV_HOST=
# ClamAV TCP port (default: 3310)
CLAMAV_PORT=3310

# ── Issue #184: Field-Level Encryption ────────────────────────────────────────
# 32-byte AES-256 key as 64 hex chars. Generate with: openssl rand -hex 32
DB_FIELD_ENCRYPTION_KEY=change-me-to-64-hex-chars-openssl-rand-hex-32
# Previous key for rotation (decrypt legacy rows). Leave empty if no rotation needed.
DB_FIELD_ENCRYPTION_KEY_PREVIOUS=

# ── Issue #202: Blockchain TX Confirmation Tracking ───────────────────────────
# Milliseconds to wait for a Soroban transaction to reach terminal state (default: 120000)
TX_CONFIRMATION_TIMEOUT_MS=120000

# ── Issue #188: WebSocket Gateway ─────────────────────────────────────────────
# Set SOCKETIO_REDIS_HOST to enable @socket.io/redis-adapter for multi-pod fan-out.
# Leave empty to use the default in-memory adapter (single pod).
SOCKETIO_REDIS_HOST=
SOCKETIO_REDIS_PORT=6379

# ── Group Waitlist ─────────────────────────────────────────────────────────────
# Maximum number of users allowed on a group's waitlist (default: 50)
GROUP_MAX_WAITLIST=50
