# Application
NODE_ENV=development
PORT=3000

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN=*

# Swagger/OpenAPI Documentation
# Swagger is enabled by default in development and disabled in production
# Uncomment the line below to enable Swagger in production environment
# SWAGGER_ENABLED=true

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=ahjoorxmr

# JWT (placeholder for future use)
# JWT_SECRET=your-secret-key
# JWT_EXPIRES_IN=1d

# KYC Webhook
# Provider: persona | jumio | onfido
KYC_PROVIDER=persona
KYC_WEBHOOK_SECRET=your-kyc-webhook-secret

# SMTP (for KYC email notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=your-smtp-password
MAIL_FROM="App <no-reply@example.com>"
